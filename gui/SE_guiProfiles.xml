<?xml version="1.0" encoding="utf-8"?>
<GUIProfiles>
    <Profile name="SE_statsColumnHeader" extends="baseReference" with="anchorTopStretchingX">
        <imageColor value="0 0 0 0"/>
    </Profile>

    <Profile name="SE_statsListItem" extends="baseReference" with="anchorTopStretchingX alternating">
        <height value="30px"/>
        <imageColor value="$preset_fs25_colorGrey"/>
        <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
        <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
    </Profile>

    <Profile name="SE_statsListSlider" extends="fs25_listSliderBox" with="anchorTopRight">
        <position value="28px -40px"/>
        <size value="6px 660px"/>
    </Profile>

    <Profile name="SE_statsHeaderText" extends="baseReference">
        <imageColor value="0 0 0 0"/>
        <textSize value="16px"/>
        <textBold value="true"/>
        <textUpperCase value="true"/>
        <textColor value="$preset_colorWhite_50"/>
        <textDisabledColor value="$preset_colorDisabled"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="SE_statsHeaderTextRight" extends="SE_statsHeaderText">
        <textAlignment value="right"/>
    </Profile>

    <Profile name="SE_statsHeaderTextCenter" extends="SE_statsHeaderText">
        <textAlignment value="center"/>
    </Profile>

    <Profile name="SE_statsRowCell" extends="baseReference" with="anchorStretchingYLeft">
        <imageColor value="0 0 0 0"/>
        <textSize value="16px"/>
        <textColor value="$preset_colorWhite"/>
        <textDisabledColor value="$preset_colorDisabled"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="SE_statsRowCellRight" extends="SE_statsRowCell">
        <textAlignment value="right"/>
    </Profile>

    <Profile name="SE_statsRowCellCenter" extends="SE_statsRowCell">
        <textAlignment value="center"/>
    </Profile>

    <Profile name="SE_statsSectionHeader" extends="baseReference" with="anchorTopStretchingX">
        <height value="34px"/>
        <imageColor value="$preset_fs25_colorMain_70"/>
    </Profile>

    <Profile name="SE_statsSectionHeaderText" extends="baseReference" with="anchorStretchingXY">
        <imageColor value="0 0 0 0"/>
        <textSize value="16px"/>
        <textBold value="true"/>
        <textUpperCase value="true"/>
        <textColor value="$preset_colorWhite"/>
        <textDisabledColor value="$preset_colorDisabled"/>
        <textAlignment value="left"/>
        <textOffset value="10px 0px"/>
    </Profile>

</GUIProfiles>
